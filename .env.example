DATABASE_URL=postgresql://user:pass@localhost:5432/sandro
SESSION_COOKIE_NAME=sd_session
ADMIN_EMAIL=sandro@example.ch
ADMIN_INITIAL_PASSWORD=change-me-now
APP_URL=http://localhost:3000

# Benachrichtigungen (optional)
# Adresse, an die neue Buchungsanfragen gemeldet werden.
ADMIN_NOTIFY_EMAIL=sandro@sandrodubach.ch
# Sobald gesetzt, kann hier später der echte Resend-Transport greifen.
# RESEND_API_KEY=

# Erlaubte iframe-Einbetter für /book (space-separated). Ohne Wert gilt der Default.
# ALLOWED_FRAME_ANCESTORS='self' https://sandrodubach.ch https://*.sandrodubach.ch http://localhost:3000

# Google Kalender (optional) — ohne diese Werte laufen App und /admin/kalender
# normal weiter; die Google-Funktionen sind dann inaktiv.
# Client-ID und Secret aus der Google Cloud Console (OAuth-2.0-Client-ID).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect-URI; muss in der Google Cloud Console exakt hinterlegt sein.
# Ohne Wert gilt der Default http://localhost:3000/api/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
# Schluessel zur Verschluesselung der gespeicherten Google-Tokens (AES-256-GCM).
# 32 Byte als base64 — erzeugen via: openssl rand -base64 32
GOOGLE_TOKEN_ENC_KEY=
